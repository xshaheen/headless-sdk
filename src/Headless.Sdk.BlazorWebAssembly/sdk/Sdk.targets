<Project>
  <Import
    Project="Sdk.targets"
    Sdk="Microsoft.NET.Sdk.BlazorWebAssembly"
    Condition="'$(_MustImportMicrosoftNETSdk)' == 'true'"
  />
  <Import
    Project="$(MSBuildThisFileDirectory)..\build\Headless.Sdk.BlazorWebAssembly.targets"
    Condition="'$(_MustImportMicrosoftNETSdk)' != 'true'"
  />
</Project>
