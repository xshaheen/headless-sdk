<Project Condition="'$(_HeadlessWindowsDesktopSdkBuildPropsImported)' != 'true'">
  <PropertyGroup>
    <_HeadlessWindowsDesktopSdkBuildPropsImported>true</_HeadlessWindowsDesktopSdkBuildPropsImported>
    <HeadlessSdkName>Headless.NET.Sdk.WindowsDesktop</HeadlessSdkName>
    <HeadlessSdkProjectType>WindowsDesktop</HeadlessSdkProjectType>
    <_HeadlessSdkDefaultIsPackable Condition="'$(_HeadlessSdkDefaultIsPackable)' == ''"
      >true</_HeadlessSdkDefaultIsPackable
    >
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)Headless.NET.Sdk.props" />
</Project>
