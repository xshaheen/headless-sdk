<Project Condition="'$(_HeadlessBlazorWebAssemblySdkBuildPropsImported)' != 'true'">
  <PropertyGroup>
    <_HeadlessBlazorWebAssemblySdkBuildPropsImported>true</_HeadlessBlazorWebAssemblySdkBuildPropsImported>
    <HeadlessSdkName>Headless.NET.Sdk.BlazorWebAssembly</HeadlessSdkName>
    <HeadlessSdkProjectType>BlazorWebAssembly</HeadlessSdkProjectType>
    <_HeadlessSdkDefaultIsPackable Condition="'$(_HeadlessSdkDefaultIsPackable)' == ''"
      >false</_HeadlessSdkDefaultIsPackable
    >
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)Headless.NET.Sdk.props" />
</Project>
