<Project Condition="'$(_HeadlessRazorSdkBuildPropsImported)' != 'true'">
  <PropertyGroup>
    <_HeadlessRazorSdkBuildPropsImported>true</_HeadlessRazorSdkBuildPropsImported>
    <HeadlessSdkName>Headless.NET.Sdk.Razor</HeadlessSdkName>
    <HeadlessSdkProjectType>Razor</HeadlessSdkProjectType>
    <_HeadlessSdkDefaultIsPackable Condition="'$(_HeadlessSdkDefaultIsPackable)' == ''"
      >true</_HeadlessSdkDefaultIsPackable
    >
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)Headless.NET.Sdk.props" />
</Project>
