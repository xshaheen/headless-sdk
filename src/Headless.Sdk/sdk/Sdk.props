<Project>
  <!--
    Hook into MSBuild's Custom* extension points so build/Headless.Sdk.props is loaded
    BEFORE the consumer's Directory.Build.props, and build/Headless.Sdk.targets BEFORE
    Microsoft.NET.Sdk's targets. This only kicks in when consumed as an MSBuild SDK
    (`<Project Sdk="Headless.Sdk">`, global.json msbuild-sdks, or `#:sdk` directive on .NET 10+).
    PackageReference consumption goes through NuGet's auto-import of build/*.props which runs
    AFTER Directory.Build.props - that path is unaffected.
  -->
  <PropertyGroup>
    <HeadlessSdkName>Headless.Sdk</HeadlessSdkName>
    <HeadlessSdkProjectType>Default</HeadlessSdkProjectType>
    <_MustImportMicrosoftNETSdk Condition="'$(UsingMicrosoftNETSdk)' != 'true'">true</_MustImportMicrosoftNETSdk>
    <_HeadlessDeferTargetFrameworkInference Condition="'$(_MustImportMicrosoftNETSdk)' == 'true'">true</_HeadlessDeferTargetFrameworkInference>

    <CustomBeforeDirectoryBuildProps>$(CustomBeforeDirectoryBuildProps);$(MSBuildThisFileDirectory)../build/Headless.Sdk.props</CustomBeforeDirectoryBuildProps>
    <BeforeMicrosoftNETSdkTargets>$(BeforeMicrosoftNETSdkTargets);$(MSBuildThisFileDirectory)../build/Headless.Sdk.targets</BeforeMicrosoftNETSdkTargets>
  </PropertyGroup>

  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" Condition="'$(_MustImportMicrosoftNETSdk)' == 'true'" />
  <Import
    Project="$(MSBuildThisFileDirectory)../build/SupportTargetFrameworkInference.props"
    Condition="'$(_MustImportMicrosoftNETSdk)' == 'true' and '$(DisableSupportTargetFrameworkInference)' != 'true'"
  />
  <!-- Inner SDK case (parent project already imported Microsoft.NET.Sdk via <Sdk Name="Headless.Sdk"...>) -->
  <Import
    Project="$(MSBuildThisFileDirectory)..\build\Headless.Sdk.props"
    Condition="'$(_MustImportMicrosoftNETSdk)' != 'true'"
  />
</Project>
