<Project>
  <ItemGroup>
    <NpmPackageFile
      Include="$(MSBuildProjectDirectory)/package.json"
      Condition="'$(HeadlessEnableNpmRestore)' == 'true'
        and '$(EnableDefaultNpmPackageFile)' != 'false'
        and Exists('$(MSBuildProjectDirectory)/package.json')"
    />
  </ItemGroup>

  <Target Name="HeadlessComputeNpmPackageMetadata">
    <PropertyGroup>
      <NpmRestoreLockedMode
        Condition="'$(NpmRestoreLockedMode)' == '' and ('$(RestoreLockedMode)' == 'true' or '$(ContinuousIntegrationBuild)' == 'true' or '$(IsContinuousIntegration)' == 'true')"
        >true</NpmRestoreLockedMode
      >
      <_HeadlessNpmRestoreCommand Condition="'$(NpmRestoreLockedMode)' == 'true'">ci</_HeadlessNpmRestoreCommand>
      <_HeadlessNpmRestoreCommand Condition="'$(NpmRestoreLockedMode)' != 'true'">install</_HeadlessNpmRestoreCommand>
    </PropertyGroup>

    <ItemGroup>
      <NpmPackageFile>
        <StampFile>$([System.IO.Path]::Combine(`%(RootDir)%(Directory)`, 'node_modules', '.npm-install-stamp'))</StampFile>
        <LockFile>$([System.IO.Path]::Combine(`%(RootDir)%(Directory)`, 'package-lock.json'))</LockFile>
        <WorkingDirectory>%(RootDir)%(Directory)</WorkingDirectory>
        <InstallCommand>npm install --no-fund --no-audit</InstallCommand>
        <RestoreCommand>npm $(_HeadlessNpmRestoreCommand) --no-fund --no-audit</RestoreCommand>
      </NpmPackageFile>
    </ItemGroup>
  </Target>

  <Target
    Name="HeadlessNpmRestore"
    DependsOnTargets="HeadlessComputeNpmPackageMetadata;HeadlessNpmRestoreForce"
    Inputs="@(NpmPackageFile)"
    Outputs="%(NpmPackageFile.StampFile)"
    BeforeTargets="Restore;CollectPackageReferences"
    Condition="'@(NpmPackageFile)' != ''"
  >
    <Message Importance="high" Text="Installing npm packages for @(NpmPackageFile)" />
    <Exec Command="%(NpmPackageFile.RestoreCommand)" WorkingDirectory="%(NpmPackageFile.WorkingDirectory)" />
    <Touch Files="@(NpmPackageFile->'%(StampFile)')" AlwaysCreate="true" />
  </Target>

  <Target
    Name="HeadlessNpmRestoreForce"
    DependsOnTargets="HeadlessCleanNpmInstallStampFile"
    Condition="'$(RestoreForce)' == 'true' and '@(NpmPackageFile)' != ''"
  />

  <Target
    Name="HeadlessCleanNpmInstallStampFile"
    DependsOnTargets="HeadlessComputeNpmPackageMetadata"
    Condition="'@(NpmPackageFile)' != ''"
  >
    <Delete Files="@(NpmPackageFile->'%(StampFile)')" />
  </Target>

  <Target Name="HeadlessNpmInstall" DependsOnTargets="HeadlessComputeNpmPackageMetadata" Condition="'@(NpmPackageFile)' != ''">
    <Exec Command="%(NpmPackageFile.InstallCommand)" WorkingDirectory="%(NpmPackageFile.WorkingDirectory)" />
  </Target>

  <Target
    Name="HeadlessEmbedNpmLockFileInBinLog"
    DependsOnTargets="HeadlessComputeNpmPackageMetadata"
    AfterTargets="CoreCompile"
    Condition="'@(NpmPackageFile)' != ''"
  >
    <ItemGroup>
      <EmbedInBinlog Include="@(NpmPackageFile->'%(LockFile)')" Condition="Exists('%(NpmPackageFile.LockFile)')" />
    </ItemGroup>
  </Target>
</Project>
