<Project>
  <PropertyGroup>
    <!-- Off by default: these process-wide STJ runtime switches can break third-party serializers such as NATS.Net. -->
    <HeadlessEnableStrictSystemTextJsonRuntimeDefaults
      Condition="'$(HeadlessEnableStrictSystemTextJsonRuntimeDefaults)' == ''"
      >false</HeadlessEnableStrictSystemTextJsonRuntimeDefaults
    >
  </PropertyGroup>

  <ItemGroup
    Label="Json Config"
    Condition="'$(HeadlessEnableStrictSystemTextJsonRuntimeDefaults)' == 'true'
      and $([MSBuild]::IsTargetFrameworkCompatible($(TargetFramework), 'net9.0')) == 'true'"
  >
    <RuntimeHostConfigurationOption
      Include="System.Text.Json.Serialization.RespectRequiredConstructorParametersDefault"
      Value="true"
    />
    <RuntimeHostConfigurationOption
      Include="System.Text.Json.Serialization.RespectNullableAnnotationsDefault"
      Value="true"
    />
  </ItemGroup>
</Project>
