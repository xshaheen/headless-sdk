<Project
  xmlns="http://schemas.microsoft.com/developer/msbuild/2003"
  Condition="'$(_HeadlessSdkBuildTargetsImported)' != 'true'"
>
  <!-- .targets files - Defines build processes or tasks to be executed during the build lifecycle. -->
  <!-- Sentinel guard - see Headless.NET.Sdk.props for rationale. -->
  <PropertyGroup>
    <_HeadlessSdkBuildTargetsImported>true</_HeadlessSdkBuildTargetsImported>
  </PropertyGroup>

  <!-- Package metadata defaults must evaluate before CI fills provider-specific repository values. -->
  <Import
    Project="$(MSBuildThisFileDirectory)SupportPackageInformation.targets"
    Condition=" '$(DisableSupportPackageInformation)' != 'true' "
  />
  <Import Project="$(MSBuildThisFileDirectory)SupportDetectContinuousIntegration.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportGeneral.targets" />
  <Import Project="$(MSBuildThisFileDirectory)RuntimeHostConfigurationOption.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportMandatoryAnalyzers.targets" />
  <Import Project="$(MSBuildThisFileDirectory)GlobalUsing.targets" />
  <Import
    Project="$(MSBuildThisFileDirectory)SupportCopyright.targets"
    Condition=" '$(DisableSupportCopyright)' != 'true' "
  />
  <Import Project="$(MSBuildThisFileDirectory)SupportNuGetAudit.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportBannedSymbols.targets" />
  <Import
    Project="$(MSBuildThisFileDirectory)SupportWebContainer.targets"
    Condition=" '$(DisableSupportWebContainer)' != 'true' "
  />
  <Import
    Project="$(MSBuildThisFileDirectory)SupportTestProjects.targets"
    Condition=" '$(HeadlessSdkProjectType)' == 'Test' and '$(IsBuildTaskProject)' != 'true' "
  />
  <Import Project="$(MSBuildThisFileDirectory)SupportAdditionalFiles.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportSystemRuntimeExperimental.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportAssemblyAttributes.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportAnalyzerHygiene.targets" />
  <Import Project="$(MSBuildThisFileDirectory)SupportSbom.targets" />
  <Import
    Project="$(MSBuildThisFileDirectory)SupportEmbedBinlog.targets"
    Condition=" '$(DisableSupportEmbedBinlog)' != 'true' "
  />
</Project>
