<Project>
  <!--
    Mandatory analyzer and banned-API references injected for every consuming project.
    This quality baseline deliberately has no consumer opt-out.
  -->
  <PropertyGroup>
    <_HeadlessMeziantouAnalyzerVersion>3.0.75</_HeadlessMeziantouAnalyzerVersion>
    <_HeadlessBannedApiAnalyzersVersion>4.14.0</_HeadlessBannedApiAnalyzersVersion>
    <_HeadlessAsyncFixerVersion>2.1.0</_HeadlessAsyncFixerVersion>
    <_HeadlessAsyncifyVersion>0.9.7</_HeadlessAsyncifyVersion>
    <_HeadlessVisualStudioThreadingAnalyzersVersion>17.14.15</_HeadlessVisualStudioThreadingAnalyzersVersion>
    <_HeadlessMultithreadingAnalyzerVersion>1.1.31</_HeadlessMultithreadingAnalyzerVersion>
    <_HeadlessRoslynatorAnalyzersVersion>4.15.0</_HeadlessRoslynatorAnalyzersVersion>
    <_HeadlessReflectionAnalyzersVersion>0.3.1</_HeadlessReflectionAnalyzersVersion>
    <_HeadlessErrorProneAnalyzersVersion>0.1.2</_HeadlessErrorProneAnalyzersVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference
      Include="Meziantou.Analyzer"
      Version="$(_HeadlessMeziantouAnalyzerVersion)"
      Condition="'$(PackageId)' != 'Meziantou.Analyzer'"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference
      Include="Microsoft.CodeAnalysis.BannedApiAnalyzers"
      Version="$(_HeadlessBannedApiAnalyzersVersion)"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference Include="AsyncFixer" Version="$(_HeadlessAsyncFixerVersion)" IsImplicitlyDefined="true">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference Include="Asyncify" Version="$(_HeadlessAsyncifyVersion)" IsImplicitlyDefined="true">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference
      Include="Microsoft.VisualStudio.Threading.Analyzers"
      Version="$(_HeadlessVisualStudioThreadingAnalyzersVersion)"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference
      Include="SmartAnalyzers.MultithreadingAnalyzer"
      Version="$(_HeadlessMultithreadingAnalyzerVersion)"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference
      Include="Roslynator.Analyzers"
      Version="$(_HeadlessRoslynatorAnalyzersVersion)"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference
      Include="ReflectionAnalyzers"
      Version="$(_HeadlessReflectionAnalyzersVersion)"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>

    <PackageReference
      Include="ErrorProne.NET.CoreAnalyzers"
      Version="$(_HeadlessErrorProneAnalyzersVersion)"
      IsImplicitlyDefined="true"
    >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
