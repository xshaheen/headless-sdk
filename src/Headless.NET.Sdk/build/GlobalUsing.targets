<Project>
  <!--
    TFM-gated usings. Item conditions are evaluated in MSBuild's item pass, which runs after the
    property pass that sets the consumer's TargetFramework, so these resolve against the final TFM
    even though the value comes from the project body. They live in .targets alongside the SDK's
    other TFM-gated item logic; functionally they would also work from .props.
  -->
  <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible($(TargetFramework), 'net5.0')) == 'true'">
    <Using Include="System.Text" />
    <Using Include="System.Text.Json" />
    <Using Include="System.Text.Json.Serialization" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible($(TargetFramework), 'net8.0')) == 'true'">
    <Using Include="System.Collections.Frozen" />
    <Using Include="System.Collections.Immutable" />
  </ItemGroup>
</Project>
