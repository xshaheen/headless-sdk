<Project>
  <!--
    Evaluate after the consumer project body so an explicit ImplicitUsings value is authoritative
    in every consumption mode. These additional namespaces require .NET 8 or later; older and
    custom target frameworks remain valid Headless consumers without receiving incompatible usings.
  -->
  <ItemGroup
    Condition=" ('$(ImplicitUsings)' == 'enable' or '$(ImplicitUsings)' == 'true')
      and '$(TargetFramework)' != ''
      and $([MSBuild]::IsTargetFrameworkCompatible($(TargetFramework), 'net8.0')) == 'true' "
  >
    <Using Include="System.Diagnostics.CodeAnalysis" />
    <Using Include="System.Globalization" />
    <Using Include="System.Text" />
    <Using Include="System.Text.Json" />
    <Using Include="System.Text.Json.Serialization" />
    <Using Include="System.Collections.Frozen" />
    <Using Include="System.Collections.Immutable" />
  </ItemGroup>
</Project>
