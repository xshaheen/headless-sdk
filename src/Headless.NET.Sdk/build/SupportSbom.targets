<Project>
  <!--
    Software Bill of Materials (SBOM) generation via Microsoft.Sbom.Targets.
    Auto-enabled on CI; explicit GenerateSBOM wins. Disable via DisableSupportSbom=true
    or set GenerateSBOM=false on the consuming project.
  -->
  <PropertyGroup>
    <GenerateSBOM
      Condition="'$(GenerateSBOM)' == '' AND ('$(IsContinuousIntegration)' == 'true' OR '$(ContinuousIntegrationBuild)' == 'true')"
      >true</GenerateSBOM
    >
  </PropertyGroup>

  <ItemGroup Condition="'$(GenerateSBOM)' == 'true'">
    <PackageReference Include="Microsoft.Sbom.Targets" Version="4.1.5" IsImplicitlyDefined="true">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
