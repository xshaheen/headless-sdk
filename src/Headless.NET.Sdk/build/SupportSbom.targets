<Project>
  <!--
    Software Bill of Materials (SBOM) generation via Microsoft.Sbom.Targets.
    Opt in with GenerateSBOM=true. Disable the support import with DisableSupportSbom=true.
  -->
  <PropertyGroup>
    <GenerateSBOM Condition="'$(GenerateSBOM)' == ''">false</GenerateSBOM>
  </PropertyGroup>

  <ItemGroup Condition="'$(GenerateSBOM)' == 'true'">
    <PackageReference Include="Microsoft.Sbom.Targets" Version="4.1.5" IsImplicitlyDefined="true">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
