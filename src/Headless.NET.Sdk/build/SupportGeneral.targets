<Project>
  <Import Project="$(MSBuildThisFileDirectory)SupportNuGetWarningPolicy.props" />

  <!--
    Re-apply the CI quality gate after the consumer project body. Named quality policy is
    intentionally authoritative; local builds retain consumer-selected warning behavior.
  -->
  <PropertyGroup
    Label="CI Quality Gate"
    Condition=" '$(_HeadlessIsKnownCiEnvironment)' == 'true' or '$(ContinuousIntegrationBuild)' == 'true' "
  >
    <CodeAnalysisTreatWarningsAsErrors>true</CodeAnalysisTreatWarningsAsErrors>
    <MSBuildTreatWarningsAsErrors>true</MSBuildTreatWarningsAsErrors>
    <WarningsAsErrors>$(WarningsAsErrors);nullable</WarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NETSDK1138;$(_HeadlessNuGetWarningsNotAsErrors)</WarningsNotAsErrors>
  </PropertyGroup>

  <!--
    NuGet restore consumes TreatWarningsAsErrors during evaluation. Set it only immediately before
    compilation so compiler and analyzer diagnostics become errors without changing restore.
  -->
  <Target
    Name="HeadlessEnableCompilerWarningsAsErrors"
    BeforeTargets="CoreCompile"
    Condition=" '$(_HeadlessIsKnownCiEnvironment)' == 'true' or '$(ContinuousIntegrationBuild)' == 'true' "
  >
    <PropertyGroup>
      <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    </PropertyGroup>
  </Target>

  <PropertyGroup Label="Conventional Test Friend Assemblies">
    <HeadlessEmitInternalsVisibleToAttributes Condition=" '$(HeadlessEmitInternalsVisibleToAttributes)' == '' "
      >true</HeadlessEmitInternalsVisibleToAttributes
    >
  </PropertyGroup>

  <ItemGroup
    Label="Test compability"
    Condition=" '$(IsTestProject)' != 'true'
      and '$(IsTestHarnessProject)' != 'true'
      and '$(HeadlessEmitInternalsVisibleToAttributes)' == 'true'
      and '$(SignAssembly)' != 'true' "
  >
    <InternalsVisibleTo Include="$(MSBuildProjectName).Tests.Architecture" />
    <InternalsVisibleTo Include="$(MSBuildProjectName).Tests.Unit" />
    <InternalsVisibleTo Include="$(MSBuildProjectName).Tests.Integration" />
    <InternalsVisibleTo Include="$(MSBuildProjectName).Tests.Acceptance" />
  </ItemGroup>

  <PropertyGroup Condition=" '$(IsTestProject)' != 'true' and '$(IsTestHarnessProject)' != 'true' ">
    <_HeadlessSdkDefaultIsPackable Condition=" '$(_HeadlessSdkDefaultIsPackable)' == '' "
      >true</_HeadlessSdkDefaultIsPackable
    >
    <IsPackable Condition=" '$(IsPackable)' == '' ">$(_HeadlessSdkDefaultIsPackable)</IsPackable>
    <IsTestProject Condition=" '$(IsTestProject)' == '' ">false</IsTestProject>
  </PropertyGroup>

  <PropertyGroup Label="Properties correction">
    <!--
      No name-based auto-classification. See SupportGeneral.props "Project Categorisation" for
      rationale: test projects use Headless.NET.Sdk.Test or set IsTestProject explicitly.
    -->
    <IsTestProject Condition=" '$(IsTestProject)' == '' ">false</IsTestProject>
    <IsPackable
      Condition=" '$(IsPackable)' == '' and ('$(IsTestProject)' == 'true' or '$(IsTestHarnessProject)' == 'true') "
      >false</IsPackable
    >
    <HeadlessSuppressNonPackablePackWarning Condition=" '$(HeadlessSuppressNonPackablePackWarning)' == '' "
      >true</HeadlessSuppressNonPackablePackWarning
    >
    <WarnOnPackingNonPackableProject
      Condition=" '$(IsPackable)' == 'false'
        and '$(HeadlessSuppressNonPackablePackWarning)' == 'true' "
      >false</WarnOnPackingNonPackableProject
    >
  </PropertyGroup>

  <PropertyGroup Label="Documentation Warnings">
    <!--
      Generate XML documentation files by default, but do not require every public API to be
      documented unless the consuming project opts in with DisableDocumentationWarnings=false.
    -->
    <NoWarn Condition="'$(DisableDocumentationWarnings)' != 'false'">$(NoWarn);CS1573;CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="ConfigureAwait Enforcement">
    <!--
      CA2007: Consider calling ConfigureAwait on the awaited task.
      Suppressed by default because most Headless apps run without a SynchronizationContext. Opt in via
      <HeadlessEnforceConfigureAwait>true</HeadlessEnforceConfigureAwait> (e.g. libraries consumed by
      Headless.NET.Sdk.WindowsDesktop apps). When enforced, the bundled
      Headless.NET.Sdk.EnforceConfigureAwait.editorconfig raises CA2007 to a warning; the redundant
      ConfigureAwait analyzers (RCS1090, MA0004, VSTHRD111) stay suppressed so only CA2007 reports.
      Evaluated here (not in SupportGeneral.props) so the consumer's HeadlessEnforceConfigureAwait
      value is already set before the suppression decision is made.
    -->
    <NoWarn Condition="'$(HeadlessEnforceConfigureAwait)' != 'true'">$(NoWarn);CA2007</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Test And Aspire NoWarn">
    <!--
      Test-project noise suppressions and the Aspire-host CA1707 relaxation. Evaluated here (not in
      SupportGeneral.props) so that IsTestProject / IsTestHarnessProject / IsAspireHost set by the
      consumer in Directory.Build.props or the csproj are visible: under MSBuild SDK consumption,
      build/Headless.NET.Sdk.props loads BEFORE Directory.Build.props, so a .props-phase condition
      would miss a consumer-set value. NoWarn is consumed at compile time, well after this point.
      CA1707/IDE1006/IDE0022/CS8604/S4144/CA5394/CA1848/MA0076/MA0003/RCS1046/CA2254/IDE0039/CA1849/
      MA0042/MA0166/CA1861/CA1859/CA1720: too noisy for test code.
      CA1707 (underscores): Aspire hosts generate members with underscores.
    -->
    <NoWarn Condition="'$(IsTestProject)' == 'true' or '$(IsTestHarnessProject)' == 'true'"
      >$(NoWarn);CA1707;IDE1006;IDE0022;CS8604;S4144;CA5394;CA1848;MA0076;MA0003;RCS1046;CA2254;IDE0039;CA1849;MA0042;MA0166;CA1861;CA1859;CA1720</NoWarn
    >
    <NoWarn Condition="'$(IsAspireHost)' == 'true'">$(NoWarn);CA1707</NoWarn>
  </PropertyGroup>

  <!--
    Allow apps to run on a newer major .NET runtime if their pinned major isn't installed.
    Applied to every non-test project: it is what executables (Exe and WinExe) need, and an inert
    no-op for libraries (RollForward only affects the runtime host, and libraries emit no
    runtimeconfig.json). Gating on OutputType is deliberately avoided so WinExe desktop apps are
    still covered. Skipped only for test projects, which should pin to the SDK they were built against.
  -->
  <PropertyGroup
    Label="RollForward"
    Condition=" '$(RollForward)' == '' and '$(IsTestProject)' != 'true' and '$(IsTestHarnessProject)' != 'true' "
  >
    <RollForward>LatestMajor</RollForward>
  </PropertyGroup>

  <PropertyGroup Label="Tool Packaging">
    <PackAsTool
      Condition=" '$(PackAsTool)' == ''
        and '$(OutputType)' == 'Exe'
        and '$(IsTestProject)' != 'true'
        and '$(IsTestHarnessProject)' != 'true'
        and '$(UsingMicrosoftNETSdkWeb)' != 'true'
        and '$(IsAspireHost)' != 'true' "
      >true</PackAsTool
    >
  </PropertyGroup>
</Project>
