<Project>
  <PropertyGroup>
    <!--
      The SDK marks consumer assemblies non-CLS-compliant by default. Set
      HeadlessEmitClsCompliantAttribute=false to skip this so you can declare your own
      [assembly: CLSCompliant(...)] (e.g. CLSCompliant(true)) without a CS0579 duplicate-attribute
      conflict.
    -->
    <HeadlessEmitClsCompliantAttribute Condition="'$(HeadlessEmitClsCompliantAttribute)' == ''"
      >true</HeadlessEmitClsCompliantAttribute
    >
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute
      Include="System.CLSCompliantAttribute"
      Condition="'$(HeadlessEmitClsCompliantAttribute)' == 'true'"
    >
      <_Parameter1>false</_Parameter1>
    </AssemblyAttribute>

    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>Headless.NET.Sdk.SdkName</_Parameter1>
      <_Parameter2>$(HeadlessSdkName)</_Parameter2>
    </AssemblyAttribute>

    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>Headless.NET.Sdk.ProjectType</_Parameter1>
      <_Parameter2>$(HeadlessSdkProjectType)</_Parameter2>
    </AssemblyAttribute>

    <AssemblyAttribute
      Include="System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute"
      Condition="'$(IsTestableProject)' == 'true' and $([MSBuild]::IsTargetFrameworkCompatible($(TargetFramework), 'net5.0')) == 'true'"
    />
  </ItemGroup>
</Project>
