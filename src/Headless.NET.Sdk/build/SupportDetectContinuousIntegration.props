<Project>
  <PropertyGroup>
    <!--
      CI provider variables are authoritative quality signals. ContinuousIntegrationBuild is the
      only consumer-facing manual activation property; the private marker keeps provider detection
      effective even when an immutable global property attempts to set it to false.
    -->
    <_HeadlessIsKnownCiEnvironment
      Condition=" '$(CI)' == 'true'
        or '$(TF_BUILD)' == 'true'
        or '$(GITHUB_ACTIONS)' == 'true'
        or '$(GITLAB_CI)' == 'true'
        or '$(TEAMCITY_VERSION)' != ''
        or '$(BUILD_COMMAND)' != ''
        or '$(APPVEYOR)' != ''
        or '$(TRAVIS)' == 'true'
        or '$(CIRCLECI)' == 'true'
        or ('$(CODEBUILD_BUILD_ID)' != '' and '$(AWS_REGION)' != '')
        or '$(JENKINS_URL)' != ''
        or ('$(BUILD_ID)' != '' and '$(BUILD_URL)' != '')
        or ('$(BUILD_ID)' != '' and '$(PROJECT_ID)' != '')
        or '$(JB_SPACE_API_URL)' != '' "
      >true</_HeadlessIsKnownCiEnvironment
    >
    <ContinuousIntegrationBuild Condition="'$(_HeadlessIsKnownCiEnvironment)' == 'true'"
      >true</ContinuousIntegrationBuild
    >

    <_HeadlessPackageLockFile
      Condition="'$(NuGetLockFilePath)' != ''"
      >$([System.IO.Path]::GetFullPath('$(NuGetLockFilePath)', '$(MSBuildProjectDirectory)'))</_HeadlessPackageLockFile
    >
    <_HeadlessPackageLockFile
      Condition="'$(NuGetLockFilePath)' == ''"
      >$([System.IO.Path]::GetFullPath('packages.lock.json', '$(MSBuildProjectDirectory)'))</_HeadlessPackageLockFile
    >
  </PropertyGroup>

  <!-- A repository opts into locked restore by committing a lock file; CI only enforces that choice. -->
  <PropertyGroup
    Condition=" ('$(_HeadlessIsKnownCiEnvironment)' == 'true' or '$(ContinuousIntegrationBuild)' == 'true')
      and Exists('$(_HeadlessPackageLockFile)') "
  >
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <RestoreLockedMode>true</RestoreLockedMode>
  </PropertyGroup>
</Project>
