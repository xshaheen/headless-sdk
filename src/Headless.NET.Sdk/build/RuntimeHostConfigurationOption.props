<Project>
  <PropertyGroup>
    <!-- Off by default: these process-wide STJ runtime switches can break third-party serializers such as NATS.Net. -->
    <HeadlessEnableStrictSystemTextJsonRuntimeDefaults
      Condition="'$(HeadlessEnableStrictSystemTextJsonRuntimeDefaults)' == ''"
      >false</HeadlessEnableStrictSystemTextJsonRuntimeDefaults
    >
  </PropertyGroup>

</Project>
