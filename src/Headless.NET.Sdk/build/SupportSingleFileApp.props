<Project>
  <!--
    FileBasedProgram is set by the .NET 10 SDK before SDK props are evaluated. File-based apps
    always receive this analyzer profile because the mandatory baseline is intentionally tuned
    differently for their single-file source model.
  -->
  <ItemGroup Condition="'$(FileBasedProgram)' == 'true'">
    <EditorConfigFiles Include="$(MSBuildThisFileDirectory)../configurations/Headless.NET.Sdk.SingleFileApp.editorconfig" />
  </ItemGroup>
</Project>
