<Project>
  <PropertyGroup>
    <IsTestProject>true</IsTestProject>
    <IsPublishable>false</IsPublishable>
    <IsPackable>false</IsPackable>

    <!-- Auto-enable code coverage on CI; explicit toggle wins. -->
    <EnableCodeCoverage
      Condition="'$(EnableCodeCoverage)' == '' AND ('$(IsContinuousIntegration)' == 'true' OR '$(ContinuousIntegrationBuild)' == 'true')"
      >true</EnableCodeCoverage
    >

    <!--
      Microsoft Testing Platform (MTP) detection happens in ItemGroup/Target conditions below
      because MSBuild item functions are not valid inside property conditions.
    -->
  </PropertyGroup>

  <!--
    Disable analyzers during dotnet test (VSTest / MTP build). Most CI pipelines run `dotnet build`
    and `dotnet test` separately; analyzers are validated in the build step, so re-running them
    during test materially slows feedback. Override with OptimizeVsTestRun=false.
  -->
  <Target
    Name="DisableAnalyzersWhenRunningTests"
    BeforeTargets="VSTest;_MTPBuild"
    Condition="'$(OptimizeVsTestRun)' != 'false'"
  >
    <PropertyGroup>
      <RunAnalyzers>false</RunAnalyzers>
    </PropertyGroup>
  </Target>

  <!-- Microsoft Testing Platform (MTP) implicit references; selection via _HeadlessUseMicrosoftTestingPlatform. -->
  <ItemGroup
    Condition="'$(UseMicrosoftTestingPlatform)' == 'true' OR (
      '$(UseMicrosoftTestingPlatform)' == '' AND (
        @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit.v3.mtp-v2')) == 'true' OR
        @(PackageReference->AnyHaveMetadataValue('Identity', 'TUnit')) == 'true'))"
  >
    <PackageReference Include="Microsoft.Testing.Extensions.CrashDump" Version="2.2.3" IsImplicitlyDefined="true" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" Version="18.7.0" IsImplicitlyDefined="true" />
    <PackageReference Include="Microsoft.Testing.Extensions.HangDump" Version="2.2.3" IsImplicitlyDefined="true" />
    <PackageReference Include="Microsoft.Testing.Extensions.HotReload" Version="2.2.3" IsImplicitlyDefined="true" />
    <PackageReference Include="Microsoft.Testing.Extensions.Retry" Version="2.2.3" IsImplicitlyDefined="true" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" Version="2.2.3" IsImplicitlyDefined="true" />
  </ItemGroup>

  <!--
    Default Microsoft Testing Platform (MTP) arguments.

    These MUST be set in a static PropertyGroup, not a BeforeTargets="_MTPBuild" target.
    The new "dotnet test" experience (global.json "runner": "Microsoft.Testing.Platform")
    reads TestingPlatformCommandLineArguments during project evaluation and does NOT run the
    legacy _MTPBuild target, so a target-based assignment never takes effect (the args get
    silently dropped: no coverage, trx, or dumps). A non-MTP (VSTest) project simply ignores
    this property, so no MTP-detection gate is needed here. Coverage settings use MTP's
    "coverage-settings" runner flag; the "settings" dotnet test CLI option is rejected by the
    MTP runner as unknown.
  -->
  <PropertyGroup Condition="'$(EnableDefaultTestSettings)' != 'false'">
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --report-trx</TestingPlatformCommandLineArguments>
    <TestingPlatformCommandLineArguments Condition="'$(EnableCodeCoverage)' == 'true'"
      >$(TestingPlatformCommandLineArguments) --coverage</TestingPlatformCommandLineArguments
    >
    <TestingPlatformCommandLineArguments Condition="'$(EnableCodeCoverage)' == 'true'"
      >$(TestingPlatformCommandLineArguments) --coverage-settings &quot;$(MSBuildThisFileDirectory)../configurations/default.runsettings&quot;</TestingPlatformCommandLineArguments
    >
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --crashdump --crashdump-type mini</TestingPlatformCommandLineArguments>
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --hangdump --hangdump-timeout 10m --hangdump-type mini</TestingPlatformCommandLineArguments>
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --minimum-expected-tests 1</TestingPlatformCommandLineArguments>
  </PropertyGroup>

  <!-- VSTest path (xUnit v2, MSTest, NUnit, etc.) -->
  <ItemGroup
    Condition="'$(UseMicrosoftTestingPlatform)' != 'true' AND (
      '$(UseMicrosoftTestingPlatform)' != '' OR (
        @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit.v3.mtp-v2')) != 'true' AND
        @(PackageReference->AnyHaveMetadataValue('Identity', 'TUnit')) != 'true'))"
  >
    <!--
      Hardcoded pin: this version is injected into consumer test projects and is NOT governed
      by the consumer's Central Package Management. Keep it in sync with the repo's own
      Directory.Packages.props Microsoft.NET.Test.Sdk version whenever bumping.
    -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.5.1" IsImplicitlyDefined="true" />
  </ItemGroup>

  <PropertyGroup Condition="'$(EnableDefaultTestSettings)' != 'false'">
    <VSTestBlame>true</VSTestBlame>

    <VSTestBlameCrash>true</VSTestBlameCrash>
    <VSTestBlameCrashDumpType>mini</VSTestBlameCrashDumpType>

    <VSTestBlameHang>true</VSTestBlameHang>
    <VSTestBlameHangDumpType>mini</VSTestBlameHangDumpType>
    <VSTestBlameHangTimeout>10min</VSTestBlameHangTimeout>

    <VSTestCollect Condition="'$(EnableCodeCoverage)' == 'true'">Code Coverage</VSTestCollect>
    <VSTestSetting Condition="'$(EnableCodeCoverage)' == 'true'"
      >$(MSBuildThisFileDirectory)../configurations/default.runsettings</VSTestSetting
    >
  </PropertyGroup>

  <PropertyGroup>
    <VSTestLogger Condition="'$(VSTestLogger)' != ''">$(VSTestLogger);</VSTestLogger>
    <VSTestLogger>$(VSTestLogger)trx;console%3bverbosity=normal</VSTestLogger>
  </PropertyGroup>

  <!-- xUnit (v2 + v3) implicit using -->
  <ItemGroup
    Condition="'$(ImplicitUsings)' == 'enable' AND (
      @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit')) == 'true' OR
      @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit.v3')) == 'true' OR
      @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit.v3.mtp-v1')) == 'true' OR
      @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit.v3.mtp-v2')) == 'true'
    )"
  >
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- GitHub Actions test logger on CI (covers VSTest path; MTP emits its own annotations) -->
  <Choose>
    <When Condition="'$(GITHUB_ACTIONS)' == 'true'">
      <PropertyGroup>
        <VSTestLogger>$(VSTestLogger);GitHubActions</VSTestLogger>
      </PropertyGroup>
      <ItemGroup>
        <PackageReference Include="GitHubActionsTestLogger" Version="2.4.1" IsImplicitlyDefined="true">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
        </PackageReference>
      </ItemGroup>
    </When>
  </Choose>
</Project>
