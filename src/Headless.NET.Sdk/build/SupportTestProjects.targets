<Project>
  <PropertyGroup>
    <!-- Headless.NET.Sdk.Test is MTP-only; xUnit uses this when generating its entry point. -->
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <IsTestProject Condition="'$(IsTestProject)' == '' AND '$(IsTestHarnessProject)' != 'true'">true</IsTestProject>
    <IsTestProject Condition="'$(IsTestProject)' == '' AND '$(IsTestHarnessProject)' == 'true'">false</IsTestProject>
    <IsTestingPlatformApplication
      Condition="'$(IsTestingPlatformApplication)' == '' AND '$(IsTestHarnessProject)' == 'true'"
      >false</IsTestingPlatformApplication
    >
    <GenerateRuntimeConfigurationFiles
      Condition="'$(GenerateRuntimeConfigurationFiles)' == '' AND '$(IsTestHarnessProject)' == 'true'"
      >true</GenerateRuntimeConfigurationFiles
    >
    <OutputType Condition="'$(IsTestHarnessProject)' == 'true'">Library</OutputType>
    <IsPublishable Condition="'$(IsPublishable)' == ''">false</IsPublishable>
    <IsPackable Condition="'$(IsPackable)' == ''">false</IsPackable>

    <!-- Auto-enable code coverage on CI; explicit toggle wins. -->
    <EnableCodeCoverage Condition="'$(EnableCodeCoverage)' == '' AND '$(ContinuousIntegrationBuild)' == 'true'"
      >true</EnableCodeCoverage
    >
  </PropertyGroup>

  <!-- The Test SDK owns these exact extension bindings, including direct consumer duplicates. -->
  <ItemGroup Condition="'$(HeadlessSdkProjectType)' == 'Test'">
    <PackageReference
      Remove="Microsoft.Testing.Extensions.CrashDump;Microsoft.Testing.Extensions.CodeCoverage;Microsoft.Testing.Extensions.HangDump;Microsoft.Testing.Extensions.HotReload;Microsoft.Testing.Extensions.Retry;Microsoft.Testing.Extensions.TrxReport"
    />
    <PackageReference
      Include="Microsoft.Testing.Extensions.CrashDump"
      Version="$(_HeadlessMtpCrashDumpVersion)"
      IsImplicitlyDefined="true"
      PrivateAssets="all"
      IncludeAssets="all"
      ExcludeAssets=""
    />
    <PackageReference
      Include="Microsoft.Testing.Extensions.CodeCoverage"
      Version="$(_HeadlessMtpCodeCoverageVersion)"
      IsImplicitlyDefined="true"
      PrivateAssets="all"
      IncludeAssets="all"
      ExcludeAssets=""
    />
    <PackageReference
      Include="Microsoft.Testing.Extensions.HangDump"
      Version="$(_HeadlessMtpHangDumpVersion)"
      IsImplicitlyDefined="true"
      PrivateAssets="all"
      IncludeAssets="all"
      ExcludeAssets=""
    />
    <PackageReference
      Include="Microsoft.Testing.Extensions.HotReload"
      Version="$(_HeadlessMtpHotReloadVersion)"
      IsImplicitlyDefined="true"
      PrivateAssets="all"
      IncludeAssets="all"
      ExcludeAssets=""
    />
    <PackageReference
      Include="Microsoft.Testing.Extensions.Retry"
      Version="$(_HeadlessMtpRetryVersion)"
      IsImplicitlyDefined="true"
      PrivateAssets="all"
      IncludeAssets="all"
      ExcludeAssets=""
    />
    <PackageReference
      Include="Microsoft.Testing.Extensions.TrxReport"
      Version="$(_HeadlessMtpTrxReportVersion)"
      IsImplicitlyDefined="true"
      PrivateAssets="all"
      IncludeAssets="all"
      ExcludeAssets=""
    />
  </ItemGroup>

  <!--
    Most CI pipelines run `dotnet build` and `dotnet test` separately. Avoid repeating analyzer
    work in MTP's test-build phase unless the consumer explicitly opts out of this optimization.
  -->
  <Target
    Name="DisableAnalyzersWhenRunningTests"
    BeforeTargets="_MTPBuild"
    Condition="'$(OptimizeTestRun)' != 'false'"
  >
    <PropertyGroup>
      <RunAnalyzers>false</RunAnalyzers>
    </PropertyGroup>
  </Target>

  <!--
    Default Microsoft Testing Platform (MTP) arguments.

    These MUST be set in a static PropertyGroup, not a BeforeTargets="_MTPBuild" target.
    The new "dotnet test" experience (global.json "runner": "Microsoft.Testing.Platform")
    reads TestingPlatformCommandLineArguments during project evaluation and does NOT run the
    legacy _MTPBuild target, so a target-based assignment never takes effect (the args get
    silently dropped: no coverage, TRX, or dumps). Coverage settings use MTP's
    "coverage-settings" runner flag.
  -->
  <PropertyGroup Condition="'$(EnableDefaultTestSettings)' != 'false'">
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --report-trx</TestingPlatformCommandLineArguments>
    <TestingPlatformCommandLineArguments Condition="'$(EnableCodeCoverage)' == 'true'"
      >$(TestingPlatformCommandLineArguments) --coverage</TestingPlatformCommandLineArguments
    >
    <TestingPlatformCommandLineArguments Condition="'$(EnableCodeCoverage)' == 'true'"
      >$(TestingPlatformCommandLineArguments) --coverage-settings &quot;$(MSBuildThisFileDirectory)../configurations/default.runsettings&quot;</TestingPlatformCommandLineArguments
    >
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --crashdump --crashdump-type mini</TestingPlatformCommandLineArguments>
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --hangdump --hangdump-timeout 10m --hangdump-type mini</TestingPlatformCommandLineArguments>
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --minimum-expected-tests 1</TestingPlatformCommandLineArguments>
  </PropertyGroup>

  <!-- xUnit MTP implicit using. The test framework remains consumer-selected. -->
  <ItemGroup
    Condition="'$(ImplicitUsings)' == 'enable' AND
      @(PackageReference->AnyHaveMetadataValue('Identity', 'xunit.v3.mtp-v2')) == 'true'"
  >
    <Using Include="Xunit" />
  </ItemGroup>
</Project>
