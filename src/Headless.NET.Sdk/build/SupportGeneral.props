<Project>
  <PropertyGroup Label="Set Repo Defaults">
    <HeadlessSdkName Condition="'$(HeadlessSdkName)' == ''">Headless.NET.Sdk</HeadlessSdkName>
    <HeadlessSdkProjectType Condition="'$(HeadlessSdkProjectType)' == ''">Default</HeadlessSdkProjectType>
    <Configuration Condition="'$(Configuration)' == ''">Debug</Configuration>
    <Platform Condition="'$(Platform)' == ''">AnyCPU</Platform>
    <PlatformName Condition="'$(PlatformName)' == ''">$(Platform)</PlatformName>
    <HeadlessEnforceConfigureAwait Condition="'$(HeadlessEnforceConfigureAwait)' == ''">false</HeadlessEnforceConfigureAwait>
  </PropertyGroup>

  <PropertyGroup Label="Project Categorisation">
    <!--
      Test classification is explicit. Consumers signal a test project via either:
        (1) <Project Sdk="Headless.NET.Sdk.Test"> sets IsTestProject=true automatically.
        (2) <IsTestProject>true</IsTestProject> in the csproj or Directory.Build.props.
        (3) <IsTestHarnessProject>true</IsTestHarnessProject> for shared harness libraries that
            should get test defaults without executing as test hosts.
    -->
    <IsTestHarnessProject Condition=" '$(IsTestHarnessProject)' == '' ">false</IsTestHarnessProject>
  </PropertyGroup>

  <PropertyGroup Label="General Configurations">
    <RootNamespace Condition="'$(RootNamespace)' == ''">$(MSBuildProjectName)</RootNamespace>
    <AssemblyName Condition="'$(AssemblyName)' == ''">$(MSBuildProjectName)</AssemblyName>

    <DefaultItemExcludes>$(DefaultItemExcludes);**/*.lscache</DefaultItemExcludes>

    <LangVersion Condition="'$(LangVersion)' == ''">latest</LangVersion>
    <WarningLevel>9999</WarningLevel>
    <Nullable Condition="'$(Nullable)' == ''">enable</Nullable>
    <ImplicitUsings Condition="'$(ImplicitUsings)' == ''">enable</ImplicitUsings>

    <GenerateDocumentationFile Condition="'$(GenerateDocumentationFile)' == ''">true</GenerateDocumentationFile>

    <Features>strict</Features>

    <AnalysisLevel>latest-all</AnalysisLevel>
    <AnalysisMode>All</AnalysisMode>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <CodeAnalysisTreatWarningsAsErrors Condition="'$(CodeAnalysisTreatWarningsAsErrors)' == ''"
      >false</CodeAnalysisTreatWarningsAsErrors
    >
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <ReportAnalyzer>true</ReportAnalyzer>
    <RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
    <RunAnalyzersDuringLiveAnalysis>true</RunAnalyzersDuringLiveAnalysis>
    <_SkipUpgradeNetAnalyzersNuGetWarning>true</_SkipUpgradeNetAnalyzersNuGetWarning>
    <SuppressNETCoreSdkPreviewMessage>false</SuppressNETCoreSdkPreviewMessage>
    <CheckEolTargetFramework>true</CheckEolTargetFramework>
    <SuppressTfmSupportBuildWarnings>false</SuppressTfmSupportBuildWarnings>

    <AccelerateBuildsInVisualStudio Condition="'$(AccelerateBuildsInVisualStudio)' == ''"
      >true</AccelerateBuildsInVisualStudio
    >

    <!-- Determinism is part of the mandatory quality baseline. -->
    <Deterministic>true</Deterministic>

    <!-- Faster + more correct restore. -->
    <RestoreUseStaticGraphEvaluation Condition="'$(RestoreUseStaticGraphEvaluation)' == ''"
      >true</RestoreUseStaticGraphEvaluation
    >
    <RestoreSerializeGlobalProperties Condition="'$(RestoreSerializeGlobalProperties)' == ''"
      >true</RestoreSerializeGlobalProperties
    >

    <!-- Run the Microsoft package-validation checks for packable projects by default. -->
    <EnablePackageValidation Condition="'$(EnablePackageValidation)' == ''">true</EnablePackageValidation>

  </PropertyGroup>

  <PropertyGroup
    Label="CI Quality Gate"
    Condition=" '$(_HeadlessIsKnownCiEnvironment)' == 'true' or '$(ContinuousIntegrationBuild)' == 'true' "
  >
    <CodeAnalysisTreatWarningsAsErrors>true</CodeAnalysisTreatWarningsAsErrors>
    <MSBuildTreatWarningsAsErrors>true</MSBuildTreatWarningsAsErrors>
    <WarningsAsErrors>$(WarningsAsErrors);nullable</WarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NETSDK1138;$(_HeadlessNuGetWarningsNotAsErrors)</WarningsNotAsErrors>
  </PropertyGroup>

  <PropertyGroup Label="NoWarn">
    <!--
      Shared suppressions for rules that are too noisy for the default SDK baseline. Documentation
      warnings are handled in SupportGeneral.targets so projects can opt in after their own props load.
      IDE0055: Fix formatting (We use CSharpier)
      IDE0010: Add missing cases to switch statement
      IDE0072: Add missing cases to switch expression
      CS1712: Type parameter 'type_parameter' has no matching typeparam tag in the XML comment on 'type_or_member' (but other type parameters do)
      CA1031: Do not catch general exception types
      CA1062: Validate arguments of public methods
      CA1054: URI parameters should not be strings
      CA1056: URI properties should not be strings
      CA1055: URI return values should not be strings
      CA2234: Pass System.Uri objects instead of strings
      CA1308: Normalize strings to uppercase
      CA1711: Identifiers should not have incorrect suffix
      CA1812: Avoid uninstantiated internal classes
      CA1034: Nested types should not be visible
      CA1724: Type names should not match namespaces
      CA1040: Avoid empty interfaces
      CA1819: Properties should not return arrays (I prefer performance)
      CA1515: Consider making public types internal
      CA1002: Do not expose generic lists (I prefer performance)
      NU5104: A stable release of a package should not have a prerelease dependency.
      MA0018: Do not declare static members on generic types (deprecated - use CA1000)
      MA0038: Make method static (deprecated - use CA1822)
      MA0041: Make property static (deprecated - use CA1822)
      MA0040: Flow the cancellation token when available (deprecated)
      MA0032: Use an overload with a CancellationToken argument (deprecated)
      MA0016: Prefer returning collection abstraction instead of implementation (I prefer performance)
      MA0048: File name must match type name (I use multiple types per file)
      MA0051: Method is too long
      MA0097: A class that implements IComparable<T> or IComparable should override comparison operators (deprecated - use  CA1036)
      CA1032;RCS1194: Implement exception constructors
      RCS1046;VSTHRD200: Asynchronous method name should end with 'Async'
      RCS1163: Unused parameter (deprecated - use dotnet_code_quality_unused_parameters, IDE0060)
      RCS1090;MA0004;VSTHRD111: Use .ConfigureAwait (deprecated - use CA2007). CA2007 itself is
        suppressed conditionally in SupportGeneral.targets (so the consumer's
        HeadlessEnforceConfigureAwait value is read first) and can be re-enabled via that property.
      AsyncFixer01: Unnecessary async/await usage
    -->
    <NoWarn>$(NoWarn);IDE0055;IDE0010;IDE0072;1712;CA1031;CA1062;CA1054;CA1056;CA1055;CA2234;CA1308;CA1711;CA1812;CA1034;CA1724;CA1040;CA1819;CA1515;CA1002;NU5104;MA0018;MA0038;MA0041;MA0040;MA0032;MA0016;MA0048;MA0051;MA0097;CA1032;RCS1194;RCS1046;VSTHRD200;RCS1163;RCS1090;MA0004;VSTHRD111;AsyncFixer01</NoWarn>
    <!--
      The IsTestProject / IsTestHarnessProject / IsAspireHost conditional NoWarn blocks live in SupportGeneral.targets,
      NOT here. Those properties can be set by the consumer in Directory.Build.props or the csproj,
      which under MSBuild SDK consumption load AFTER this .props file (build/Headless.NET.Sdk.props is
      wired via CustomBeforeDirectoryBuildProps, i.e. before Directory.Build.props). Evaluating the
      suppressions in .targets (which loads after Directory.Build.props) honors a consumer-set value
      in every consumption mode. Same rationale as the documentation-warning and CA2007 NoWarn blocks
      already in SupportGeneral.targets.
    -->
  </PropertyGroup>

  <PropertyGroup Label="Language Configuration">
    <NeutralLanguage Condition="'$(NeutralLanguage)' == ''">en</NeutralLanguage>
    <PreferredUILang Condition="'$(PreferredUILang)' == ''">en</PreferredUILang>
  </PropertyGroup>
</Project>
