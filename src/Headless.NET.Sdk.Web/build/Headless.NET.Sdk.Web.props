<Project Condition="'$(_HeadlessWebSdkBuildPropsImported)' != 'true'">
  <PropertyGroup>
    <_HeadlessWebSdkBuildPropsImported>true</_HeadlessWebSdkBuildPropsImported>
    <HeadlessSdkName>Headless.NET.Sdk.Web</HeadlessSdkName>
    <HeadlessSdkProjectType>Web</HeadlessSdkProjectType>
    <_HeadlessSdkDefaultIsPackable Condition="'$(_HeadlessSdkDefaultIsPackable)' == ''"
      >false</_HeadlessSdkDefaultIsPackable
    >
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)Headless.NET.Sdk.props" />
</Project>
